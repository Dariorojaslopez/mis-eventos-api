# Application
APP_NAME=Mis Eventos API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (async PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/mis_eventos
DATABASE_ECHO=false

# Security / JWT
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Logging
LOG_LEVEL=INFO
LOG_JSON=true

# AI (descripciones de eventos)
AI_PROVIDER=mock
OPENAI_API_KEY=
AI_OPENAI_MODEL=gpt-4o-mini
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF_SECONDS=0.5
AI_RATE_LIMIT_REQUESTS=10
AI_RATE_LIMIT_WINDOW_SECONDS=60
